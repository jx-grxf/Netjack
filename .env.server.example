# Server
PORT=3001
MAX_PLAYERS=2

# Comma-separated list of allowed browser origins for CORS.
# For local dev, keep localhost:5173.
CLIENT_URLS=http://localhost:5173

# Admin endpoint is disabled by default.
# Set to true and provide ADMIN_USER + ADMIN_PASS to enable /admin/stats.
ADMIN_ENABLED=false
ADMIN_USER=
ADMIN_PASS=
