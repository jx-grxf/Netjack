# Client
# Optional: explicit Socket.IO endpoint. By default it resolves to <current-host>:3001.
VITE_SOCKET_URL=

# Optional: explicit admin endpoint URL. By default it resolves to <current-host>:3001/admin/stats.
VITE_ADMIN_API_URL=

# Admin UI is hidden unless explicitly enabled.
VITE_ENABLE_ADMIN_UI=false
